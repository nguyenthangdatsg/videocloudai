# Server
PORT=3002
NODE_ENV=development

# Database
DATABASE_PATH=./database/videocloudai.db

# Assets
ASSETS_DIR=./assets
CACHE_DIR=./cache
RENDERS_DIR=./renders

# AI Providers
GOOGLE_FLOW_API_KEY=
GOOGLE_IMAGEFX_API_KEY=
GOOGLE_PROJECT_ID=

# Edge TTS
EDGE_TTS_VOICE=en-US-GuyNeural

# Whisper
WHISPER_MODEL=tiny
WHISPER_LANGUAGE=en

# FFmpeg
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Queue
MAX_CONCURRENT_JOBS=3
JOB_TIMEOUT_MS=300000

# Rate Limits
GOOGLE_FLOW_RPM=10
GOOGLE_IMAGEFX_RPM=20
