{
  "manifest_version": 3,
  "name": "Han2YT",
  "version": "1.1.0",
  "description": "Bulk generate images & videos on Google Flow, Grok, and ChatGPT — feed them into VideoCloudAI storyboard automatically.",
  "permissions": ["sidePanel", "downloads", "storage", "tabs", "scripting", "debugger"],
  "host_permissions": [
    "https://labs.google/*",
    "https://grok.com/*",
    "https://chatgpt.com/*",
    "http://localhost:5174/*",
    "http://localhost:5173/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Han2YT",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://labs.google/fx/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content_chatgpt.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://grok.com/*"],
      "js": ["content_grok.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost:5174/*", "http://localhost:5173/*", "http://localhost/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
